msgstr "<b>Directoris</b>"

#: ../src/roxterm-config.ui:3111
msgid "Filer"
msgstr "Filer"

#: ../src/roxterm-config.ui:3126
msgid "File manager to use when a directory URI is opened."
msgstr "Gestor de fitxers a utilitzar quan s'obre un URI de directori."

#: ../src/roxterm-config.ui:3148 ../src/roxterm-config.ui:3265
msgid "Run the filer without a terminal."
msgstr "Executa el fitxerr sense terminal."

#: ../src/roxterm-config.ui:3170 ../src/roxterm-config.ui:3287
msgid "Run the filer in a new ROXTerm window."
msgstr "Executa el fitxerr en una finestra ROXTerm nova."

#: ../src/roxterm-config.ui:3192 ../src/roxterm-config.ui:3308
msgid "Run the filer in a new ROXTerm tab."
msgstr "Executa el fitxerr en una pestanya ROXTerm nova."

#: ../src/roxterm-config.ui:3209
msgid "<b>Files</b>"
msgstr "<b>Fitxers</b>"

#: ../src/roxterm-config.ui:3226
msgid "_Filer"
msgstr "Filer"

#: ../src/roxterm-config.ui:3243
msgid "File manager to use when a file URI is opened."
msgstr "Gestor de fitxers a utilitzar quan s'obre un URI de fitxer."

#: ../src/roxterm-config.ui:3323
msgid "O_pen parent directory instead"
msgstr "Obre el directori pare"

#: ../src/roxterm-config.ui:3329
msgid "If set open the file's parent directory instead of the file."
msgstr "Si s'estableix, obre el directori pare del fitxer en lloc del fitxer."

#: ../src/roxterm-config.ui:3344
msgid "_Match filenames without file:// prefix"
msgstr "Concorda amb noms de fitxer sense prefix file://"

#: ../src/roxterm-config.ui:3349
msgid ""
"If enabled, patterns which look like filenames will be highlighted even if "
"they lack a file:// URI prefix."
msgstr ""
"Si està activada, els patrons que s'assemblen als noms de fitxer es "
"ressaltaran encara que no tinguin un prefix URI file://."

#: ../src/roxterm-config.ui:3399
msgid "_No scrollbar"
msgstr "Sense barra de desplaçament"

#: ../src/roxterm-config.ui:3417
msgid "Scrollbar on _right"
msgstr "Barra de desplaçament a la dreta"

#: ../src/roxterm-config.ui:3435
msgid "Scrollbar on _left"
msgstr "Barra de desplaçament a l'esquerra"

#: ../src/roxterm-config.ui:3453
msgid "Scroll on _output"
msgstr "Desplaçament a la sortida"

#: ../src/roxterm-config.ui:3459
msgid ""
"Whether to make the scrollbar jump to the bottom when new text is printed in"
" the terminal"
msgstr ""
"Si s'ha de fer que la barra de desplaçament salti a la part inferior quan "
"s'imprimeixi text nou al terminal"

#: ../src/roxterm-config.ui:3472
msgid "Scroll on _keystroke"
msgstr "Desplaça en prémer la tecla"

#: ../src/roxterm-config.ui:3478
msgid ""
"Whether to make the scrollbar jump to the bottom when text is typed into a "
"terminal"
msgstr ""
"Si s'ha de fer que la barra de desplaçament salti a la part inferior quan el"
" text s'escriu en un terminal"

#: ../src/roxterm-config.ui:3512
msgid "Changes to the scrollbar position only take effect in new windows."
msgstr ""
"Els canvis a la posició de la barra de desplaçament només tenen efecte en "
"les finestres noves."

#: ../src/roxterm-config.ui:3538
msgid ""
"Number of lines of output text to retain in the buffer so that they can "
"still be viewed by scrolling up"
msgstr ""
"Nombre de línies de text de sortida a retenir a la memòria intermèdia perquè"
" encara es puguin veure desplaçant cap amunt"

#: ../src/roxterm-config.ui:3541
msgid "1000"
msgstr "1000"

#: ../src/roxterm-config.ui:3559
msgid "l_ines"
msgstr "línies"

#: ../src/roxterm-config.ui:3572
msgid "Li_mit scrollback:"
msgstr "Limita el desplaçament enrere:"

#: ../src/roxterm-config.ui:3600
msgid "<b>Scrolling</b>"
msgstr "<b>Desplaçament</b>"

#: ../src/roxterm-config.ui:3613
msgid "Background"
msgstr "Fons"

#: ../src/roxterm-config.ui:3643
msgid "_Backspace key generates:"
msgstr "La tecla de retrocés genera:"

#: ../src/roxterm-config.ui:3658 ../src/roxterm-config.ui:3689
msgid "Automatic choice"
msgstr "Selecció automàtica"

#: ../src/roxterm-config.ui:3659 ../src/roxterm-config.ui:3690
msgid "Ctrl-H"
msgstr "Ctrl-H"

#: ../src/roxterm-config.ui:3660 ../src/roxterm-config.ui:3691
msgid "ASCII DEL"
msgstr "ASCII DEL"

#: ../src/roxterm-config.ui:3661 ../src/roxterm-config.ui:3692
msgid "Escape sequence"
msgstr "Seqüència d'escapament"

#: ../src/roxterm-config.ui:3674
msgid "_Delete key generates:"
msgstr "La tecla de supressió genera:"

#: ../src/roxterm-config.ui:3703
msgid "_Reset to defaults"
msgstr "Restableix als valors predeterminats"

#: ../src/roxterm-config.ui:3709
msgid "Reset the backspace and delete keys to their defaults"
msgstr ""
"Restableix el retrocés i suprimeix les claus als seus valors predeterminats"

#: ../src/roxterm-config.ui:3722
msgid "Disable menu _access key (F10 by default)"
msgstr "Inhabilita la clau d'accés al menú (F10 per defecte)"

#: ../src/roxterm-config.ui:3729
msgid ""
"This option disables the keyboard shortcut for opening the first menu. The "
"default shortcut is F10."
msgstr ""
"Aquesta opció inhabilita la drecera de teclat per a obrir el primer menú. La"
" drecera predeterminada és F10."

#: ../src/roxterm-config.ui:3743
msgid "Disable other menu _shortcut keys (Alt+...)"
msgstr "Inhabilita altres tecles de drecera de menú (Alt+...)"

#: ../src/roxterm-config.ui:3750
msgid ""
"This option disables the underlined shortcut keys in the menus (eg Alt+F for"
" the File menu)."
msgstr ""
"Aquesta opció desactiva les tecles de drecera subratllades als menús (p. ex."
" Alt+F per al menú Fitxer)."

#: ../src/roxterm-config.ui:3764
msgid "Disable _tab switching shortcut keys (Alt+number)"
msgstr ""
"Desactiva les tecles de drecera de commutació de pestanyes (Alt+number)"

#: ../src/roxterm-config.ui:3771
msgid ""
"This option disables the shortcut keys for switching tabs (Alt+1-9 and Alt+0"
" by default)"
msgstr ""
"Aquesta opció desactiva les tecles de drecera per a canviar de pestanya "
"(Alt+1-9 i Alt+0 per defecte)"

#: ../src/roxterm-config.ui:3791
msgid "<b>Keyboard</b>"
msgstr "<b>Teclat</b>"

#: ../src/roxterm-config.ui:3838
msgid "_Tab title:"
msgstr "Títol de la pestanya:"

#: ../src/roxterm-config.ui:3851
msgid ""
"The title string may include '%s' which is substituted with the title set by"
" the child command (usually the current directory for shells). No other % "
"characters or sequences are permitted except '%%' which is displayed as a "
"single %."
msgstr ""
"La cadena de títol pot incloure «%s», que se substitueix pel títol establert"
" per l'ordre filla (normalment el directori actual per als shells). No es "
"permeten altres % caràcters o seqüències excepte «%%», que es mostra com un "
"% únic."

#: ../src/roxterm-config.ui:3866
msgid "S_how number"
msgstr "Mostra el número"

#: ../src/roxterm-config.ui:3871
msgid ""
"This option causes the tab number to be shown at the start of the title."
msgstr ""
"Aquesta opció fa que el número de pestanya es mostri a l'inici del títol."

#: ../src/roxterm-config.ui:3898
msgid "<b>Middle click on label action</b>"
msgstr "<b>Clic del mig a l'acció de l'etiqueta</b>"

#: ../src/roxterm-config.ui:3909
msgid "Do n_othing"
msgstr "No facis res"

#: ../src/roxterm-config.ui:3928
msgid "C_lose tab"
msgstr "Tanca la pestanya"

#: ../src/roxterm-config.ui:3947
msgid "_Paste tab name"
msgstr "Enganxa el nom de la pestanya"

#: ../src/roxterm-config.ui:3966
msgid "_Wrap when switching tabs"
msgstr "Ajusta en canviar de pestanya"

#: ../src/roxterm-config.ui:3974
msgid ""
"This option makes the Next and Previous Tab operations respectively wrap "
"around from the first and last tab to the opposite end of the row; the move "
"tab left/right/up/down menu items are affected similarly."
msgstr ""
"Aquesta opció fa que les operacions Pestanya següent i anterior s'ajustin "
"respectivament des de la primera i última pestanya a l'extrem oposat de la "
"fila; els elements del menú Mou la pestanya esquerra/dreta/amunt/avall es "
"veuran afectats de manera similar."

#: ../src/roxterm-config.ui:3987
msgid "Show Close _buttons on tabs"
msgstr "Mostra els botons de tancament a les pestanyes"

#: ../src/roxterm-config.ui:3995
msgid "If this option is enabled close buttons are shown at the top of tabs."
msgstr ""
"Si aquesta opció està activada, els botons de tancament es mostren a la part"
" superior de les pestanyes."

#: ../src/roxterm-config.ui:4009
msgid "Show terminal _status in close buttons"
msgstr "Mostra l'estat del terminal als botons de tancament"

#: ../src/roxterm-config.ui:4017
msgid ""
"If this option is enabled the icons in close buttons may be changed in "
"inactive tabs to reflect the status of their terminals."
msgstr ""
"Si aquesta opció està activada, les icones dels botons de tancament es poden"
" canviar en pestanyes inactives per a reflectir l'estat dels seus terminals."

#: ../src/roxterm-config.ui:4030
msgid "Open new tabs _adjacent to current tab"
msgstr "Obre les pestanyes noves adjacents a la pestanya actual"

#: ../src/roxterm-config.ui:4037
msgid ""
"Whether to open new tabs adjacent to the current tab in a window, otherwise "
"append them."
msgstr ""
"Si s'han d'obrir les pestanyes noves adjacents a la pestanya actual en una "
"finestra, en cas contrari les afegiu."

#: ../src/roxterm-config.ui:4092
msgid ""
"The tab position option does not apply to windows that are already open; "
"only to windows opened subsequently."
msgstr ""
"L'opció de posició de la pestanya no s'aplica a les finestres que ja estan "
"obertes; només a les finestres obertes posteriorment."

#: ../src/roxterm-config.ui:4119
msgid "Tab pos_ition:"
msgstr "Posició de la pestanya:"

#: ../src/roxterm-config.ui:4136
msgid "Top"
msgstr "A dalt"

#: ../src/roxterm-config.ui:4137
msgid "Bottom"
msgstr "A baix"

#: ../src/roxterm-config.ui:4138
msgid "Left"
msgstr "Esquerra"

#: ../src/roxterm-config.ui:4139
msgid "Right"
msgstr "Dreta"

#: ../src/roxterm-config.ui:4140
msgid "Hidden"
msgstr "Ocult"

#: ../src/roxterm-config.ui:4163
msgid "<b>Tabs</b>"
msgstr "<b>pestanyes</b>"

#: ../src/roxterm-config.ui:4271
msgid "_Address"
msgstr "Adreça"

#: ../src/roxterm-config.ui:4285
msgid "Ssh server address."
msgstr "Adreça del servidor Ssh."

#: ../src/roxterm-config.ui:4304
msgid "_User"
msgstr "Usuari"

#: ../src/roxterm-config.ui:4318
msgid "Remote username."
msgstr "Nom d'usuari remot."

#: ../src/roxterm-config.ui:4335
msgid "_Port"
msgstr "Port"

#: ../src/roxterm-config.ui:4349
msgid "Ssh server port."
msgstr "Port del servidor Ssh."

#: ../src/roxterm-config.ui:4378
msgid "_Other options"
msgstr "Altres opcions"

#: ../src/roxterm-config.ui:4392
msgid "Miscellaneous options to add to the ssh command line."
msgstr "Opcions diverses per a afegir a la línia d'ordres ssh."
